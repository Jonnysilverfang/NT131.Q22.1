# RSA Task 2.1.1 + 2.1.2

p = 11
q = 17
e = 7
M = 5

# Hàm Euclid mở rộng
def egcd(a, b):
    if b == 0:
        return a, 1, 0
    g, x1, y1 = egcd(b, a % b)
    x = y1
    y = x1 - (a // b) * y1
    return g, x, y

# Hàm tìm nghịch đảo modulo
def mod_inverse(a, m):
    g, x, y = egcd(a, m)
    if g != 1:
        raise ValueError("Khong ton tai nghich dao modulo")
    return x % m

n = p * q
phi = (p - 1) * (q - 1)
d = mod_inverse(e, phi)

print("n =", n)
print("phi(n) =", phi)
print("Public key (e, n) =", (e, n))
print("Private key (d, n) =", (d, n))

# Encryption for Confidentiality
C_conf = pow(M, e, n)
M_conf_dec = pow(C_conf, d, n)

print("\n=== Encryption for Confidentiality ===")
print("Ciphertext =", C_conf)
print("Decrypted plaintext =", M_conf_dec)

# Encryption for Authentication
C_auth = pow(M, d, n)
M_auth_dec = pow(C_auth, e, n)

print("\n=== Encryption for Authentication ===")
print("Ciphertext =", C_auth)
print("Decrypted plaintext =", M_auth_dec)
