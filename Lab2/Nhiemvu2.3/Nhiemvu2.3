from Crypto.Cipher import DES

def doi_sang_bit(data):
    return format(int.from_bytes(data, 'big'), '064b')

def dem_bit_khac_nhau(a, b):
    return sum(bit1 != bit2 for bit1, bit2 in zip(a, b))

def thu_voi_khoa(khoa):
    p1 = b'STAYHOME'
    p2 = b'STAYHOMA'

    des = DES.new(khoa, DES.MODE_ECB)

    c1 = des.encrypt(p1)
    c2 = des.encrypt(p2)

    bit1 = doi_sang_bit(c1)
    bit2 = doi_sang_bit(c2)

    so_bit_khac = dem_bit_khac_nhau(bit1, bit2)
    ti_le = so_bit_khac / 64 * 100

    print("========================================")
    print("Khoa:", khoa.decode())
    print("Ban ma 1 (hex):", c1.hex())
    print("Ban ma 2 (hex):", c2.hex())
    print("Ban ma 1 (bit):", bit1)
    print("Ban ma 2 (bit):", bit2)
    print("So bit khac nhau:", so_bit_khac)
    print("Ti le thay doi bit: {:.2f}%".format(ti_le))
    print()

def main():
    ds_khoa = [
        b'24521068',
        b'24520885',
        b'24521253'
    ]

    for khoa in ds_khoa:
        thu_voi_khoa(khoa)

if __name__ == "__main__":
    main()
